<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToHeight="false" fitToWidth="true" hbarPolicy="NEVER" styleClass="hide-scrollbars" style="-fx-background-color: #EBF1F6;" stylesheets="@../css/style.css" vbarPolicy="NEVER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.teknisio.controller.ChatController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: transparent;">
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <children>
            
            <!-- Header: Back Button & Title -->
            <StackPane prefHeight="50.0">
               <children>
                  <!-- Back button left aligned -->
                  <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleBack" styleClass="back-btn" StackPane.alignment="CENTER_LEFT">
                     <graphic>
                        <SVGPath content="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z" fill="#2D4B73" />
                     </graphic>
                  </Button>
                  
                  <!-- Centered Title -->
                  <Label styleClass="section-title" text="Chat" style="-fx-font-size: 16px;" StackPane.alignment="CENTER" />
               </children>
            </StackPane>
            
            <!-- Card Section: Chat List -->
            <VBox styleClass="chat-card">
               <children>
                  
                  <!-- Chat Row 1: Ahmed Rush -->
                  <HBox fx:id="chatAhmedRow" alignment="CENTER_LEFT" onMouseClicked="#handleAhmedClick" styleClass="chat-row">
                     <children>
                        <!-- Avatar -->
                        <StackPane styleClass="chat-avatar-wrapper">
                           <children>
                              <ImageView fx:id="ahmedAvatar" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="false">
                                 <image>
                                    <Image url="@../images/tech_ahmed.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </StackPane>
                        
                        <!-- Middle Details -->
                        <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="chat-name" text="Ahmed Rush" />
                              <Label styleClass="chat-message" text="I will come around 2 PM, Please be at home" />
                           </children>
                        </VBox>
                        
                        <!-- Right Status Details -->
                        <VBox alignment="TOP_RIGHT" spacing="6.0" prefWidth="60.0">
                           <children>
                              <Label styleClass="chat-time" text="08.43" />
                              <StackPane styleClass="chat-unread-badge">
                                 <children>
                                    <Label styleClass="chat-unread-text" text="2" />
                                 </children>
                              </StackPane>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Chat Row 2: Evan Bran -->
                  <HBox fx:id="chatEvanRow" alignment="CENTER_LEFT" onMouseClicked="#handleEvanClick" styleClass="chat-row-last">
                     <children>
                        <!-- Avatar -->
                        <StackPane styleClass="chat-avatar-wrapper">
                           <children>
                              <ImageView fx:id="evanAvatar" fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="false">
                                 <image>
                                    <Image url="@../images/tech_devon.png" />
                                 </image>
                              </ImageView>
                           </children>
                        </StackPane>
                        
                        <!-- Middle Details -->
                        <VBox alignment="CENTER_LEFT" spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="chat-name" text="Evan Bran" />
                              <Label styleClass="chat-message" text="Thank you for calling me" />
                           </children>
                        </VBox>
                        
                        <!-- Right Status Details -->
                        <VBox alignment="TOP_RIGHT" prefWidth="60.0">
                           <children>
                              <Label styleClass="chat-time" text="4/22/46" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
               </children>
            </VBox>
            
         </children>
      </VBox>
   </content>
</ScrollPane>
